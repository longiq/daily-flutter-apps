# Copy file này thành .env khi chạy local (không commit .env thật lên Git).
# Trên Render, set các biến này trong tab "Environment" của Web Service.

# Bắt buộc — lấy free tại https://aistudio.google.com/apikey (không cần thẻ).
GEMINI_API_KEY=

# Tùy chọn — model Gemini free tier (mặc định gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash

# Tùy chọn nhưng nên đặt — chuỗi bí mật tự chọn, app Flutter phải gửi kèm
# header "x-proxy-key" khớp giá trị này mới gọi được /api/generate.
# Không phải bảo mật tuyệt đối (vẫn nhúng trong app build ra) nhưng chặn bớt
# bot dò URL và cho phép xoay vòng nhanh nếu bị lộ.
PROXY_SECRET=

# Tùy chọn — danh sách origin được phép gọi (CORS), phân tách bằng dấu phẩy.
# Để "*" nếu app mobile gọi trực tiếp (không phải web browser).
ALLOWED_ORIGINS=*

# Tùy chọn — giới hạn request cho /api/generate (chống lạm dụng quota free).
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30

# Tùy chọn — giới hạn độ dài prompt (ký tự).
MAX_PROMPT_CHARS=8000

# PORT do Render tự set, không cần khai báo khi deploy.
PORT=3000
